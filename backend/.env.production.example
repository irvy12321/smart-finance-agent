# Production environment template for the FastAPI backend.
# Copy this file to backend/.env and replace every placeholder before deploy.

# Required. Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=replace-with-a-64-byte-random-secret

# Required for first boot. If omitted, the app generates a one-time admin
# password and prints it to startup logs, which is inconvenient for production.
DEFAULT_ADMIN_PASSWORD=replace-with-a-strong-admin-password

# Production should fail closed instead of silently returning simulated data.
ALLOW_MOCK_DATA=false

# LiteLLM should not fetch the remote model cost map during startup in
# restricted or offline environments.
LITELLM_LOCAL_MODEL_COST_MAP=true

# Runtime environment.
ENVIRONMENT=production
PYTHONUNBUFFERED=1

# Auth token lifetime.
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS origins, comma-separated. Replace with the real frontend origin.
CORS_ORIGINS=https://your-domain.example

# LLM provider selection: mimo or deepseek.
LLM_PROVIDER=mimo
MIMO_API_KEY=replace-with-mimo-api-key
DEEPSEEK_API_KEY=
ZHIPU_API_KEY=

# Optional model routing tiers. Leave blank to use the active provider model.
# LLM_LIGHTWEIGHT_MODEL=openai/glm-4-flash
# LLM_STANDARD_MODEL=openai/deepseek-chat
# LLM_HIGH_QUALITY_MODEL=openai/mimo-v2.5-pro

# Market data providers. In production, configure real providers instead of
# enabling mock data.
FINNHUB_API_KEY=
NEWS_API_KEY=
ALPHA_VANTAGE_API_KEY=
FMP_API_KEY=

# Observability.
SENTRY_DSN=
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_CONSOLE_EXPORT=false

# LLM audit logging. Keep enabled unless storage/legal policy says otherwise.
LLM_CALL_LOG_ENABLED=true
LLM_CALL_LOG_MAX_LEN=4000

# RAG upload safety limit.
RAG_MAX_UPLOAD_BYTES=10485760
