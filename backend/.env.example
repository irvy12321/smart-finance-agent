# JWT Secret Key (REQUIRED — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
JWT_SECRET_KEY=your-jwt-secret-key-here

# Access Token expiry in minutes (default: 15)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh Token expiry in days (default: 7)
REFRESH_TOKEN_EXPIRE_DAYS=7

# 小米MiMo官方API Key
# 获取地址: https://api.xiaomimimo.com
MIMO_API_KEY=your-mimo-api-key-here

# DeepSeek API Key (备选)
# 获取地址: https://platform.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Active Provider Selection
# 可选值: mimo, deepseek
LLM_PROVIDER=mimo

# 智谱 GLM API Key（SmartRouter 轻量档 glm-4-flash，基本免费）
# 获取地址: https://bigmodel.cn → API Keys
# ZHIPU_API_KEY=your-zhipu-api-key-here

# SmartRouter 复杂度分档路由（按问题复杂度选模型降本，留空则全部回退到 LLM_PROVIDER 默认模型）
#   轻量档（简单问题）/ 标准档（中等）/ 高质量档（复杂问题）
#   需为对应模型配好 key：glm-4-flash→ZHIPU_API_KEY, deepseek-chat→DEEPSEEK_API_KEY, mimo-v2.5-pro→MIMO_API_KEY
# LLM_LIGHTWEIGHT_MODEL=openai/glm-4-flash
# LLM_STANDARD_MODEL=openai/deepseek-chat
# LLM_HIGH_QUALITY_MODEL=openai/mimo-v2.5-pro

# 可选: Finnhub API Key（新闻主用源；company-news 按股票代码查询，免费档 60 次/分）
# 获取地址: https://finnhub.io/register
# FINNHUB_API_KEY=your-finnhub-key

# 可选: News API Key（新闻备用源；注意 newsapi.org 免费档仅限本机开发，生产服务器会被拒）
# 获取地址: https://newsapi.org/
# NEWS_API_KEY=your-news-api-key

# 可选: Alpha Vantage API Key（用于真实股价/历史数据；免费版每天 25 次）
# 获取地址: https://www.alphavantage.co/support/#api-key
# ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# 可选: Financial Modeling Prep API Key（用于真实财报数据）
# 获取地址: https://site.financialmodelingprep.com/developer/docs
# FMP_API_KEY=your-fmp-key

# 数据兜底开关（默认 true）：
#   true  = 无 key / API 失败 / 额度用尽时，回退到带显式标记的模拟数据（演示永远有数据）
#   false = 严格模式，取不到真实数据时直接报错，不回退模拟数据
ALLOW_MOCK_DATA=true

# Sentry DSN for error monitoring
# 获取地址: https://sentry.io/settings/projects/
SENTRY_DSN=

# Environment (development, staging, production)
ENVIRONMENT=development

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
