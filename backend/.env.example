# JWT Secret Key (REQUIRED — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
JWT_SECRET_KEY=your-jwt-secret-key-here

# 小米MiMo官方API Key
# 获取地址: https://api.xiaomimimo.com
MIMO_API_KEY=your-mimo-api-key-here

# DeepSeek API Key (备选)
# 获取地址: https://platform.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Active Provider Selection
# 可选值: mimo, deepseek
LLM_PROVIDER=mimo

# 可选: News API Key（用于真实新闻搜索）
# 获取地址: https://newsapi.org/
# NEWS_API_KEY=your-news-api-key

# Sentry DSN for error monitoring
# 获取地址: https://sentry.io/settings/projects/
SENTRY_DSN=

# Environment (development, staging, production)
ENVIRONMENT=development

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
