# JWT Secret Key (REQUIRED — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
JWT_SECRET_KEY=your-jwt-secret-key-here

# Access Token expiry in minutes (default: 15)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh Token expiry in days (default: 7)
REFRESH_TOKEN_EXPIRE_DAYS=7

# 小米MiMo官方API Key
# 获取地址: https://api.xiaomimimo.com
MIMO_API_KEY=your-mimo-api-key-here

# DeepSeek API Key (备选)
# 获取地址: https://platform.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Active Provider Selection
# 可选值: mimo, deepseek
LLM_PROVIDER=mimo

# 可选: News API Key（用于真实新闻搜索）
# 获取地址: https://newsapi.org/
# NEWS_API_KEY=your-news-api-key

# 可选: Alpha Vantage API Key（用于真实股价/历史数据；免费版每天 25 次）
# 获取地址: https://www.alphavantage.co/support/#api-key
# ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# 可选: Financial Modeling Prep API Key（用于真实财报数据）
# 获取地址: https://site.financialmodelingprep.com/developer/docs
# FMP_API_KEY=your-fmp-key

# 数据兜底开关（默认 true）：
#   true  = 无 key / API 失败 / 额度用尽时，回退到带显式标记的模拟数据（演示永远有数据）
#   false = 严格模式，取不到真实数据时直接报错，不回退模拟数据
ALLOW_MOCK_DATA=true

# Sentry DSN for error monitoring
# 获取地址: https://sentry.io/settings/projects/
SENTRY_DSN=

# Environment (development, staging, production)
ENVIRONMENT=development

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
